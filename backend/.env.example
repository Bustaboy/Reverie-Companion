# Reverie backend settings
REVERIE_APP_NAME="Reverie Backend"
REVERIE_APP_VERSION="0.1.0"
REVERIE_DEBUG=false
REVERIE_LOG_LEVEL="INFO"

# Ollama must be running locally: https://ollama.com
REVERIE_OLLAMA_HOST="http://localhost:11434"
REVERIE_OLLAMA_MODEL="llama3.1:8b"
REVERIE_OLLAMA_TIMEOUT_SECONDS=120

# Default generation settings tuned for responsive local chat.
REVERIE_DEFAULT_TEMPERATURE=0.75
REVERIE_DEFAULT_TOP_P=0.9
REVERIE_DEFAULT_NUM_PREDICT=512

# JSON list parsed by pydantic-settings.
REVERIE_CORS_ORIGINS='["http://localhost:1420","http://localhost:5173"]'

# Local long-term memory settings. Data stays on disk under backend/data by default.
# These defaults are conservative for 8GB systems: embedded LanceDB, one local
# Ollama embedding call per write/search, small context blocks, and no reranker.
REVERIE_MEMORY_ENABLED=true
REVERIE_MEMORY_DB_PATH="./data/memory"
REVERIE_MEMORY_STORE_PROVIDER="reverie_lancedb"
REVERIE_MEMORY_COLLECTION_NAME="reverie_memories"
REVERIE_MEMORY_DEFAULT_USER_ID="local_user"
# Optional session scope. Leave empty for cross-session user memory.
REVERIE_MEMORY_DEFAULT_SESSION_ID=
REVERIE_MEMORY_EMBEDDING_MODEL="nomic-embed-text"
REVERIE_MEMORY_EMBEDDING_DIMENSIONS=768
# Leave unset to reuse REVERIE_OLLAMA_MODEL for mem0 extraction/reflection.
REVERIE_MEMORY_LLM_MODEL=
REVERIE_MEMORY_EXTRACTION_TEMPERATURE=0.1
REVERIE_MEMORY_ADD_INFER=true
# Direct LanceDB scores are not calibrated yet; raise only after observing data.
REVERIE_MEMORY_SEARCH_MIN_SCORE=0.0
REVERIE_MEMORY_MAX_MEMORY_CHARS=4000
REVERIE_MEMORY_MAX_CONTEXT_MEMORIES=6
REVERIE_MEMORY_CONTEXT_MAX_CHARS=4000
REVERIE_MEMORY_MEM0_ENABLED=true

# Self-reflection journal settings. Reflection writes are throttled background
# work; prompt injection only reads compact local journal summaries.
REVERIE_REFLECTION_ENABLED=true
REVERIE_REFLECTION_USER_MESSAGE_INTERVAL=6
REVERIE_REFLECTION_MIN_INTERVAL_SECONDS=180
REVERIE_REFLECTION_HISTORY_MESSAGE_LIMIT=12
REVERIE_REFLECTION_CONTEXT_ENTRY_LIMIT=5
REVERIE_REFLECTION_CONTEXT_MAX_CHARS=1600

# Local TTS. Orpheus-CPP is the primary emotional voice path and stays on CPU
# by default so it does not compete with ComfyUI on 8GB GPUs. Piper remains the
# fast fallback voice when Orpheus is unavailable or too slow for a request.
# See docs/TTS_SETUP.md for model download and smoke-test commands.
REVERIE_TTS_ENABLED=true
REVERIE_TTS_PRIMARY_BACKEND="orpheus"
REVERIE_TTS_ORPHEUS_RUNTIME="cpp"
REVERIE_TTS_ORPHEUS_MODEL_ID="canopylabs/orpheus-3b-0.1-ft"
REVERIE_TTS_ORPHEUS_CPP_MODEL_ID="isaiahbjork/orpheus-3b-0.1-ft-Q4_K_M-GGUF"
REVERIE_TTS_ORPHEUS_MODEL_PATH=
REVERIE_TTS_ORPHEUS_TIMEOUT_SECONDS=120
REVERIE_TTS_ORPHEUS_DEFAULT_VOICE_ID="tara"
REVERIE_TTS_ORPHEUS_CPP_LANGUAGE="en"
REVERIE_TTS_ORPHEUS_CPP_N_GPU_LAYERS=0
REVERIE_TTS_ORPHEUS_CPP_N_THREADS=0
REVERIE_TTS_ORPHEUS_CPP_N_CTX=4096
REVERIE_TTS_ORPHEUS_CPP_PRE_BUFFER_SECONDS=1.0
REVERIE_TTS_DEVICE="cpu"
REVERIE_TTS_QUANTIZATION="4bit"
REVERIE_TTS_MIN_FREE_VRAM_MB=3600

# Piper fallback. Leave the binary path empty when running from an activated
# backend venv. Set an absolute path if Uvicorn starts without the venv active.
REVERIE_TTS_PIPER_BINARY_PATH=
REVERIE_TTS_PIPER_VOICE_DIR="./models/piper"
REVERIE_TTS_PIPER_MODEL_PATH="./models/piper/reverie_default.onnx"
REVERIE_TTS_PIPER_TIMEOUT_SECONDS=20

# 8GB local AI hotswap. Keep enabled on RTX 4070-class GPUs so Ollama and
# ComfyUI do not keep large models resident at the same time.
REVERIE_LOCAL_AI_HOTSWAP_ENABLED=true
REVERIE_LOCAL_AI_HOTSWAP_TIMEOUT_SECONDS=3
REVERIE_LOCAL_AI_UNLOAD_OLLAMA_BEFORE_IMAGES=true
REVERIE_LOCAL_AI_UNLOAD_COMFYUI_BEFORE_CHAT=true

# Local image generation / Moment Capture. ComfyUI is optional for chat, but
# actual rendered images require a running ComfyUI server and a model workflow.
# The checked-in default workflow uses the Apache-2.0 Comfy-Org Flux Schnell
# FP8 checkpoint and avoids the non-commercial Flux Dev model.
# See docs/COMFYUI_SETUP.md for the full 8GB setup and model downloads.
REVERIE_IMAGE_GENERATION_ENABLED=true
REVERIE_IMAGE_GENERATION_COMFYUI_URL="http://127.0.0.1:8188"
REVERIE_IMAGE_GENERATION_OUTPUT_DIR="./data/images/generated"
REVERIE_IMAGE_GENERATION_HISTORY_PATH="./data/images/history.json"
REVERIE_IMAGE_GENERATION_DEFAULT_PRESET="preview_8gb"
REVERIE_IMAGE_GENERATION_MIN_FREE_VRAM_MB=2800
REVERIE_IMAGE_GENERATION_MAX_QUEUE_SIZE=8
REVERIE_IMAGE_GENERATION_COMFY_TIMEOUT_SECONDS=600
REVERIE_IMAGE_GENERATION_RESUME_POLL_SECONDS=2
REVERIE_IMAGE_GENERATION_CPU_FALLBACK=true
REVERIE_IMAGE_GENERATION_ALLOW_UNKNOWN_VRAM=true

REVERIE_IMAGE_GENERATION_COMFYUI_WORKFLOW_PATH="../config/comfyui/reverie-flux-schnell-fp8.api.json"
REVERIE_IMAGE_GENERATION_COMFYUI_POSITIVE_NODE_ID="3"
REVERIE_IMAGE_GENERATION_COMFYUI_POSITIVE_INPUT="text"
REVERIE_IMAGE_GENERATION_COMFYUI_NEGATIVE_NODE_ID="4"
REVERIE_IMAGE_GENERATION_COMFYUI_NEGATIVE_INPUT="text"
REVERIE_IMAGE_GENERATION_COMFYUI_WIDTH_NODE_ID="5"
REVERIE_IMAGE_GENERATION_COMFYUI_WIDTH_INPUT="width"
REVERIE_IMAGE_GENERATION_COMFYUI_HEIGHT_NODE_ID="5"
REVERIE_IMAGE_GENERATION_COMFYUI_HEIGHT_INPUT="height"
REVERIE_IMAGE_GENERATION_COMFYUI_STEPS_NODE_ID="6"
REVERIE_IMAGE_GENERATION_COMFYUI_STEPS_INPUT="steps"
REVERIE_IMAGE_GENERATION_COMFYUI_GUIDANCE_NODE_ID="6"
REVERIE_IMAGE_GENERATION_COMFYUI_GUIDANCE_INPUT="cfg"
REVERIE_IMAGE_GENERATION_COMFYUI_SEED_NODE_ID="6"
REVERIE_IMAGE_GENERATION_COMFYUI_SEED_INPUT="seed"
REVERIE_IMAGE_GENERATION_COMFYUI_SAVE_NODE_ID="8"
REVERIE_IMAGE_GENERATION_COMFYUI_SAVE_INPUT="filename_prefix"
