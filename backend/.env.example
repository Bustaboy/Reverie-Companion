# Reverie backend settings
REVERIE_APP_NAME="Reverie Backend"
REVERIE_APP_VERSION="0.1.0"
REVERIE_DEBUG=false
REVERIE_LOG_LEVEL="INFO"

# Ollama must be running locally: https://ollama.com
REVERIE_OLLAMA_HOST="http://localhost:11434"
REVERIE_OLLAMA_MODEL="llama3.1:8b"
REVERIE_OLLAMA_TIMEOUT_SECONDS=120

# Default generation settings tuned for responsive local chat.
REVERIE_DEFAULT_TEMPERATURE=0.75
REVERIE_DEFAULT_TOP_P=0.9
REVERIE_DEFAULT_NUM_PREDICT=512

# JSON list parsed by pydantic-settings.
REVERIE_CORS_ORIGINS='["http://localhost:5173"]'

# Local long-term memory settings. Data stays on disk under backend/data by default.
# These defaults are conservative for 8GB systems: embedded LanceDB, one local
# Ollama embedding call per write/search, small context blocks, and no reranker.
REVERIE_MEMORY_ENABLED=true
REVERIE_MEMORY_DB_PATH="./data/memory"
REVERIE_MEMORY_STORE_PROVIDER="reverie_lancedb"
REVERIE_MEMORY_COLLECTION_NAME="reverie_memories"
REVERIE_MEMORY_DEFAULT_USER_ID="local_user"
# Optional session scope. Leave empty for cross-session user memory.
REVERIE_MEMORY_DEFAULT_SESSION_ID=
REVERIE_MEMORY_EMBEDDING_MODEL="nomic-embed-text"
REVERIE_MEMORY_EMBEDDING_DIMENSIONS=768
# Leave unset to reuse REVERIE_OLLAMA_MODEL for mem0 extraction/reflection.
REVERIE_MEMORY_LLM_MODEL=
REVERIE_MEMORY_EXTRACTION_TEMPERATURE=0.1
REVERIE_MEMORY_ADD_INFER=true
# Direct LanceDB scores are not calibrated yet; raise only after observing data.
REVERIE_MEMORY_SEARCH_MIN_SCORE=0.0
REVERIE_MEMORY_MAX_MEMORY_CHARS=4000
REVERIE_MEMORY_MAX_CONTEXT_MEMORIES=6
REVERIE_MEMORY_CONTEXT_MAX_CHARS=4000
REVERIE_MEMORY_MEM0_ENABLED=true

# Self-reflection journal settings. Reflection writes are throttled background
# work; prompt injection only reads compact local journal summaries.
REVERIE_REFLECTION_ENABLED=true
REVERIE_REFLECTION_USER_MESSAGE_INTERVAL=6
REVERIE_REFLECTION_MIN_INTERVAL_SECONDS=180
REVERIE_REFLECTION_HISTORY_MESSAGE_LIMIT=12
REVERIE_REFLECTION_CONTEXT_ENTRY_LIMIT=5
REVERIE_REFLECTION_CONTEXT_MAX_CHARS=1600
