# Reverie backend runtime settings
REVERIE_APP_NAME="Reverie Backend"
REVERIE_APP_VERSION="0.1.0"
REVERIE_ENVIRONMENT="development"
REVERIE_LOG_LEVEL="INFO"

# API server
REVERIE_API_HOST="127.0.0.1"
REVERIE_API_PORT=8000

# Ollama
REVERIE_OLLAMA_HOST="http://127.0.0.1:11434"
REVERIE_OLLAMA_MODEL="llama3.1:8b"
REVERIE_OLLAMA_REQUEST_TIMEOUT=120

# Generation defaults
REVERIE_DEFAULT_TEMPERATURE=0.8
REVERIE_DEFAULT_TOP_P=0.9
