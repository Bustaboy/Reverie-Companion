# Reverie backend settings
REVERIE_APP_NAME="Reverie Backend"
REVERIE_APP_VERSION="0.1.0"
REVERIE_DEBUG=false
REVERIE_LOG_LEVEL="INFO"

# Ollama must be running locally: https://ollama.com
REVERIE_OLLAMA_HOST="http://localhost:11434"
REVERIE_OLLAMA_MODEL="llama3.1:8b"
REVERIE_OLLAMA_TIMEOUT_SECONDS=120

# Default generation settings tuned for responsive local chat.
REVERIE_DEFAULT_TEMPERATURE=0.75
REVERIE_DEFAULT_TOP_P=0.9
REVERIE_DEFAULT_NUM_PREDICT=512

# JSON list parsed by pydantic-settings.
REVERIE_CORS_ORIGINS='["http://localhost:5173"]'
